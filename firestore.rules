rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isChatParticipant(chatId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participante_ids;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId);

      match /chats_ocultos/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /historial_oculto/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /language/{docId} {
      allow read: if signedIn();
    }

    match /interests/{docId} {
      allow read: if signedIn();
    }

    match /language_user/{docId} {
      allow read: if signedIn()
        && (!resource.exists || request.auth.uid == resource.data.usuario_id);
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.usuario_id;
      allow update, delete: if signedIn()
        && request.auth.uid == resource.data.usuario_id;
    }

    match /usuariointeres/{docId} {
      allow read: if signedIn()
        && (!resource.exists || request.auth.uid == resource.data.usuario_id);
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.usuario_id;
      allow update, delete: if signedIn()
        && request.auth.uid == resource.data.usuario_id;
    }

    match /chats/{chatId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.participante_ids;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participante_ids;
      allow update: if signedIn()
        && request.auth.uid in resource.data.participante_ids;

      match /mensajes/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId)
          && request.auth.uid == request.resource.data.emisor_id;
        allow update: if isChatParticipant(chatId);
      }

      match /typing/{docId} {
        allow read, write: if isChatParticipant(chatId);
      }
    }

    match /match_queue/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isOwner(userId);
    }

    match /video_sessions/{sessionId} {
      allow read, write: if signedIn();
    }

    match /audio_sessions/{sessionId} {
      allow read, write: if signedIn();
    }

    match /historial_llamadas/{docId} {
      allow read, write: if signedIn();
    }

    match /user_blocks/{docId} {
      allow read, create, delete: if signedIn();
    }

    match /denuncias/{docId} {
      allow read, create: if signedIn();
    }
  }
}
